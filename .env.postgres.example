# Local Postgres defaults for Artana Resource Library
# Copy to .env.postgres (gitignored) and adjust as needed.

# Docker container configuration
ARTANA_POSTGRES_DB=artana_dev
ARTANA_POSTGRES_USER=artana_dev
ARTANA_POSTGRES_PASSWORD=artana_dev_password
ARTANA_POSTGRES_PORT=5432
ARTANA_POSTGRES_HOST=localhost

# SQLAlchemy connection strings
DATABASE_URL=postgresql+psycopg2://artana_dev:artana_dev_password@localhost:5432/artana_dev
ASYNC_DATABASE_URL=postgresql+asyncpg://artana_dev:artana_dev_password@localhost:5432/artana_dev
ALEMBIC_DATABASE_URL=postgresql+psycopg2://artana_dev:artana_dev_password@localhost:5432/artana_dev
FLUJO_STATE_URI=postgresql://artana_dev:artana_dev_password@localhost:5432/artana_dev?options=-c%20search_path=flujo,public

# Hybrid graph + embeddings feature flags (default OFF)
ARTANA_ENABLE_ENTITY_EMBEDDINGS=0
ARTANA_ENABLE_RELATION_SUGGESTIONS=0

# Optional PubMed discovery configuration
# Leave ARTANA_PUBMED_SEARCH_BACKEND unset for the default behavior:
# deterministic during tests, live NCBI E-utilities in local/dev/prod.
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=artana-resource-library

# Admin credentials used for seeding/reset scripts (set to a strong local-only value)
ARTANA_ADMIN_PASSWORD=change_me_locally1
